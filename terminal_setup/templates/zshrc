# zsh configuration for long-lived interactive shells.
# Inspired by https://github.com/josean-dev/dev-environment-files
# This file is generated by terminal-setup; edit the template in the repo.

# History
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt APPEND_HISTORY
setopt INC_APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_VERIFY

# Navigation
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt EXTENDED_GLOB

# Ensure user-local binaries are available (starship, fd, bat shims).
export PATH="$HOME/.local/bin:$PATH"

# Completion
autoload -Uz compinit
compinit -d ~/.zcompdump
zstyle ":completion:*" menu select
zstyle ":completion:*" matcher-list "m:{a-zA-Z}={A-Za-z}"

# Key bindings
bindkey -e
bindkey "^[[H" beginning-of-line
bindkey "^[[F" end-of-line
bindkey "^[[3~" delete-char
bindkey '^[[A' history-search-backward
bindkey '^[[B' history-search-forward

# Windows-style line selection: Shift+Home/End select from the cursor to the
# start/end of the line. Once a region is active, Backspace and Delete remove
# the selected text. These sequences are what WezTerm sends for Shift+Home/End.
select-to-beginning-of-line() {
  ((REGION_ACTIVE)) || zle set-mark-command
  zle beginning-of-line
}
zle -N select-to-beginning-of-line
bindkey "\e[1;2H" select-to-beginning-of-line

select-to-end-of-line() {
  ((REGION_ACTIVE)) || zle set-mark-command
  zle end-of-line
}
zle -N select-to-end-of-line
bindkey "\e[1;2F" select-to-end-of-line

# Terminal integration: OSC 7 reports the cwd (WezTerm tab titles and
# new-tab inheritance), OSC 133 marks prompt starts so WezTerm can jump
# between prompts (Ctrl+Shift+Up/Down) in long scrollback. Terminals that
# do not understand these sequences ignore them.
__osc_report_cwd() {
  printf '\033]7;file://%s%s\033\\' "${HOST:-localhost}" "${PWD// /%20}"
}
__osc_prompt_mark() {
  __osc_report_cwd
  printf '\033]133;A\033\\'
}
__osc_command_mark() {
  printf '\033]133;C\033\\'
}
autoload -Uz add-zsh-hook
add-zsh-hook precmd __osc_prompt_mark
add-zsh-hook preexec __osc_command_mark

# Aliases
alias reload-zsh="source ~/.zshrc"
alias edit-zsh="${EDITOR:-nano} ~/.zshrc"
alias clear="clear -x"
alias cl="clear -x"
alias ll="ls -la"
alias ..="cd .."
alias ...="cd ../.."
alias grep="grep --color=auto"
alias tm="tmux"
alias tma="tmux attach"

# Use eza if available (josean-dev style)
if command -v eza >/dev/null 2>&1; then
  alias ls="eza --icons=auto"
  alias ll="eza -la --icons=auto"
fi

# Use bat if available (josean-dev style)
if command -v bat >/dev/null 2>&1; then
  if bat --list-themes 2>/dev/null | grep -qx "tokyonight_night"; then
    export BAT_THEME=tokyonight_night
  else
    unset BAT_THEME
  fi
  alias cat="bat"
fi

# Use zoxide if available (josean-dev style)
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
  alias cd="z"
fi

# Use direnv for per-project environment loading.
if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

# just command runner shorthand
if command -v just >/dev/null 2>&1; then
  alias j="just"
fi

# fzf integration (josean-dev style)
if command -v fzf >/dev/null 2>&1; then
  # Newer fzf versions support `fzf --zsh`; older distro builds expose scripts only.
  if fzf --zsh >/dev/null 2>&1; then
    eval "$(fzf --zsh)"
  else
    [[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ]] && source /usr/share/doc/fzf/examples/key-bindings.zsh
    [[ -f /usr/share/doc/fzf/examples/completion.zsh ]] && source /usr/share/doc/fzf/examples/completion.zsh
  fi

  fg="#CBE0F0"
  bg="#011628"
  bg_highlight="#143652"
  purple="#B388FF"
  blue="#06BCE4"
  cyan="#2CF9ED"
  export FZF_DEFAULT_OPTS="--color=fg:${fg},bg:${bg},hl:${purple},fg+:${fg},bg+:${bg_highlight},hl+:${purple},info:${blue},prompt:${cyan},pointer:${cyan},marker:${cyan},spinner:${cyan},header:${cyan}"

  if command -v fd >/dev/null 2>&1; then
    export FZF_DEFAULT_COMMAND="fd --hidden --strip-cwd-prefix --exclude .git"
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND="fd --type=d --hidden --strip-cwd-prefix --exclude .git"
  fi
fi

# Optional starship prompt
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi

# Local overrides (keep last)
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
