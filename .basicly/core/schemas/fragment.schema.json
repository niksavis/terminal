{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basicly.dev/schemas/fragment.schema.json",
  "title": "basicly fragment source",
  "description": "A fragment authored as <id>.fragment.yaml, projected into the always-on files.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "description", "category", "applies_to", "body"],
  "properties": {
    "schema_version": {
      "const": 1,
      "description": "Source-format version; bump only when the loader contract changes."
    },
    "id": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "category": {
      "enum": [
        "boundaries",
        "code-style",
        "commands",
        "decisions",
        "design",
        "hooks",
        "project",
        "security",
        "skills",
        "testing",
        "tools",
        "ci-cd"
      ]
    },
    "priority": {"enum": ["critical", "high", "medium", "low"]},
    "applies_to": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "tags": {"type": "array", "items": {"type": "string"}},
    "status": {"enum": ["active", "draft", "deprecated"]},
    "title": {"type": "string"},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "properties": {"paths": {"type": "array", "items": {"type": "string"}}}
    },
    "source": {"enum": ["core", "user"]},
    "override": {"type": "boolean"},
    "replaces": {"type": "array", "items": {"type": "string"}},
    "extends": {"type": "array", "items": {"type": "string"}},
    "enforced_by": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "description": "Commands/tools that mechanically enforce this rule (§3.1); each must be cited in the body."
    },
    "body": {"type": "string", "minLength": 1}
  }
}
